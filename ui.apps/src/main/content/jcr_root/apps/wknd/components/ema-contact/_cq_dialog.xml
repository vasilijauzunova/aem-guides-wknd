<?xml version="1.0" encoding="UTF-8"?>
<jcr:root xmlns:sling="http://sling.apache.org/jcr/sling/1.0" xmlns:cq="http://www.day.com/jcr/cq/1.0" xmlns:jcr="http://www.jcp.org/jcr/1.0"
          xmlns:nt="http://www.jcp.org/jcr/nt/1.0"
          jcr:primaryType="nt:unstructured"
          jcr:title="Ema Contact Component"
          sling:resourceType="cq/gui/components/authoring/dialog">
    <content
            jcr:primaryType="nt:unstructured"
            sling:resourceType="granite/ui/components/coral/foundation/container">
        <layout
                jcr:primaryType="nt:unstructured"
                sling:resourceType="granite/ui/components/coral/foundation/layouts/tabs"
                type="nav"/>
        <items jcr:primaryType="nt:unstructured">
            <properties
                    jcr:primaryType="nt:unstructured"
                    jcr:title="Contact"
                    sling:resourceType="granite/ui/components/coral/foundation/container">
                <layout
                        jcr:primaryType="nt:unstructured"
                        sling:resourceType="granite/ui/components/coral/foundation/layouts/fixedcolumns"/>
                <items jcr:primaryType="nt:unstructured">
                    <title jcr:primaryType="nt:unstructured"
                           sling:resourceType="granite/ui/components/coral/foundation/form/textfield"
                           fieldLabel="Title"
                           fieldDescription="Enter a title for this contact"
                           name="./title"/>
                    <firstName jcr:primaryType="nt:unstructured"
                               sling:resourceType="granite/ui/components/coral/foundation/form/textfield"
                               fieldLabel="First name"
                               fieldDescription="Enter your first name"
                               name="./firstName"
                               required="{Boolean}true"/>
                    <lastName jcr:primaryType="nt:unstructured"
                              sling:resourceType="granite/ui/components/coral/foundation/form/textfield"
                              fieldLabel="Last name"
                              fieldDescription="Enter your last name"
                              name="./lastName"
                              required="{Boolean}true"/>
                    <phoneNumber jcr:primaryType="nt:unstructured"
                                 sling:resourceType="granite/ui/components/coral/foundation/form/textfield"
                                 fieldLabel="Phone number"
                                 fieldDescription="Enter a valid phone number"
                                 name="./phoneNumber"
                                 required="{Boolean}true"/>
                    <emailAddress jcr:primaryType="nt:unstructured"
                                  sling:resourceType="granite/ui/components/coral/foundation/form/textfield"
                                  fieldLabel="Email Address"
                                  fieldDescription="Enter a valid email address"
                                  name="./emailAddress"
                                  type="email"/>

                </items>
            </properties>
        </items>
    </content>
</jcr:root>